msgstr "Tafsir của trang %(page)s từ Kinh Qur'an | Kinh Qur'an"

#, python-format
msgid "Surah %(surah_name)s | Read and listen - Wird Quran"
msgstr "Surah %(surah_name)s | Đọc và nghe - Wird Qur'an"

